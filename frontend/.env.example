# ── Sprawl Protocol — environment template ──────────────────────────────────
# Copy to .env.local and fill in. .env.local is gitignored.

# ── Chain ────────────────────────────────────────────────────────────────────
# A PRIVATE RPC is required for the live engine (the public Mantle RPC rate-limits
# eth_getLogs/eth_call and breaks the indexer + agent reads). Alchemy works well.
MANTLE_SEPOLIA_RPC_URL=https://mantle-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployer / backend wallet (signs registrations, funding, market-maker, settlement).
BACKEND_PRIVATE_KEY=your_deployer_private_key_hex

# AES-256-GCM key (32 bytes hex) for encrypting agent wallet private keys at rest.
BACKEND_ENCRYPTION_KEY=your_32_byte_hex_key

# ── Agent brains (DeepSeek drives strategy_type=2 / LLM agents) ───────────────
DEEPSEEK_API_KEY=your_deepseek_key

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Avatar generation (OPTIONAL) ─────────────────────────────────────────────
# The avatar pipeline tries these in order, then no-key Pollinations, then
# DiceBear as a last resort. Set ANY ONE for reliable AI avatars; all are free
# tier (Gemini image-gen needs billing enabled on the API project).
#
# Cloudflare Workers AI (recommended — reliable, generous free tier, flux-1-schnell)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_workers_ai_token
#
# Together AI (free model: FLUX.1-schnell-Free)
# TOGETHER_API_KEY=your_together_key
#
# Hugging Face Inference (free token, FLUX.1-schnell)
# HUGGINGFACE_API_KEY=your_hf_token
#
# Google Gemini image gen (needs billing on the API project — free tier = 0 quota)
# GEMINI_API_KEY=your_gemini_key
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
